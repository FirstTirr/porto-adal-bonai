---
import Layout from '../layouts/Layout.astro';
import { getProjects } from '../server/projects';
import { getArticles } from '../server/articles';
import { getSettings } from '../server/settings';

const projects = await getProjects();
const articles = await getArticles();
const settings = await getSettings();

const getSetting = (key: string, defaultValue: string = '') => settings[key] || defaultValue;

const homeBadge = getSetting("home_badge", "Welcome");
const homeTitle1 = getSetting("home_title1", "Hi, I'm");
const homeTitle2 = getSetting("home_title2", "A Creative Professional");
const homeDesc = getSetting("home_desc", "I craft modern, aesthetic, and functional digital experiences.");
const homeImg = getSetting("home_img", "https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&q=80&w=800");

const aboutTitle = getSetting("about_title", "About Me");
const aboutName = getSetting("about_name", "Author");
const aboutRole = getSetting("about_role", "Creator");
const aboutImg = getSetting("about_img", "https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&q=80&w=800");
const aboutLocation = getSetting("about_location", "Global");
const aboutJourney = getSetting("about_journey", "My journey is fueled by passion and continuous learning.");
const aboutFocus = getSetting("about_focus", "I focus on delivering high impact results.");

const socialWa = getSetting("social_wa", "");
const socialIg = getSetting("social_ig", "");
const socialTiktok = getSetting("social_tiktok", "");
const socialLinkedin = getSetting("social_linkedin", "");
const socialFacebook = getSetting("social_facebook", "");
const socialX = getSetting("social_x", "");
---

<Layout>
  <!-- Background Decorative Blobs -->
  <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden bg-[#fafafa]">
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-indigo-300/20 blur-[120px]"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-purple-300/20 blur-[120px]"></div>
  </div>

  <!-- Full Screen Snap Container -->
  <div class="relative z-10 w-full overflow-x-hidden font-sans selection:bg-indigo-500/30 scroll-smooth">
    
    <!-- AREA 1: HOME -->
    <section id="home" class="w-full min-h-screen flex items-center justify-center relative px-6 md:px-12 pt-20 pb-10">
      <div class="max-w-[1400px] w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="flex flex-col z-10 w-full order-2 lg:order-1">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-slate-200 shadow-sm w-fit mb-8">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
            <span class="text-xs font-bold tracking-widest uppercase text-slate-600">{homeBadge}</span>
          </div>
          <h1 class="text-5xl md:text-7xl lg:text-8xl font-black text-slate-900 tracking-tighter leading-[0.9] mb-6">
            <span class="bg-clip-text text-transparent bg-gradient-to-br from-slate-900 to-slate-500">{homeTitle1}</span>
            <span class="block text-indigo-600 mt-2 font-bold tracking-tight">{homeTitle2}</span>
          </h1>
          <p class="text-base md:text-xl text-slate-500 leading-relaxed max-w-lg mb-10 font-normal">
            {homeDesc}
          </p>
          <div class="flex flex-wrap gap-5 items-center">
            <a href="#gallery" class="px-8 py-4 bg-slate-900 text-white font-bold rounded-full hover:bg-indigo-600 hover:shadow-xl hover:shadow-indigo-500/20 hover:-translate-y-1 transition-all duration-300 text-sm flex items-center gap-2 group">
              Explore Gallery
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </a>            <div class="flex items-center gap-3">
              {socialWa && (
                <a href={socialWa} target="_blank" rel="noopener noreferrer" class="w-12 h-12 flex items-center justify-center rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-emerald-50 hover:text-emerald-600 hover:border-emerald-200 transition-all shadow-sm hover:shadow-md hover:-translate-y-1" aria-label="WhatsApp">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.405-.883-.733-1.48-1.64-1.653-1.937-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                </a>
              )}
              {socialIg && (
                <a href={socialIg} target="_blank" rel="noopener noreferrer" class="w-12 h-12 flex items-center justify-center rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-pink-50 hover:text-pink-600 hover:border-pink-200 transition-all shadow-sm hover:shadow-md hover:-translate-y-1" aria-label="Instagram">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
              )}
              {socialTiktok && (
                <a href={socialTiktok} target="_blank" rel="noopener noreferrer" class="w-12 h-12 flex items-center justify-center rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-100 hover:text-black hover:border-slate-300 transition-all shadow-sm hover:shadow-md hover:-translate-y-1" aria-label="TikTok">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 2.78-1.15 5.54-3.33 7.37-1.92 1.62-4.55 2.28-6.95 1.88-2.61-.45-4.96-2.06-6.1-4.46-1.16-2.58-1-5.63.45-8.08 1.34-2.28 3.73-3.85 6.35-4.31v4.06c-1.39.28-2.73.98-3.66 2.05-1.07 1.25-1.5 3.01-1.1 4.61.35 1.42 1.33 2.67 2.66 3.23 1.32.55 2.92.51 4.18-.18 1.46-.78 2.45-2.31 2.58-3.98.05-11.23.01-22.45.03-33.68z"/></svg>
                </a>
              )}
              {socialLinkedin && (
                <a href={socialLinkedin} target="_blank" rel="noopener noreferrer" class="w-12 h-12 flex items-center justify-center rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-blue-50 hover:text-blue-700 hover:border-blue-200 transition-all shadow-sm hover:shadow-md hover:-translate-y-1" aria-label="LinkedIn">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              )}
              {socialFacebook && (
                <a href={socialFacebook} target="_blank" rel="noopener noreferrer" class="w-12 h-12 flex items-center justify-center rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-blue-50 hover:text-blue-600 hover:border-blue-200 transition-all shadow-sm hover:shadow-md hover:-translate-y-1" aria-label="Facebook">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              )}
              {socialX && (
                <a href={socialX} target="_blank" rel="noopener noreferrer" class="w-12 h-12 flex items-center justify-center rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-100 hover:text-black hover:border-slate-300 transition-all shadow-sm hover:shadow-md hover:-translate-y-1" aria-label="X (Twitter)">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
                </a>
              )}
            </div>          </div>
        </div>
        
        <div class="flex justify-center relative order-1 lg:order-2 w-full max-w-[450px] lg:max-w-[500px] mx-auto">
          <div class="absolute inset-0 bg-gradient-to-tr from-indigo-500/20 to-purple-500/20 rounded-3xl blur-2xl transform rotate-3"></div>
          <div class="w-full aspect-square bg-white rounded-3xl p-2 overflow-hidden relative shadow-2xl z-10 group border border-white/50 backdrop-blur-sm transition-transform duration-700 hover:scale-[1.02]">
             <img src={homeImg} alt="Hero" class="w-full h-full object-cover rounded-2xl grayscale-[10%] group-hover:grayscale-0 transition-all duration-1000" />
          </div>
        </div>
      </div>
    </section>

    <!-- AREA 2: ABOUT -->
    <section id="about" class="w-full min-h-screen flex items-center justify-center relative px-6 md:px-12 pt-20 pb-10">
      <div class="max-w-[1400px] w-full h-full max-h-[850px] flex flex-col justify-center">
        
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
          <div class="hidden lg:block lg:col-span-4 relative group w-full">
             <div class="absolute -inset-2 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-3xl opacity-20 group-hover:opacity-40 blur-lg transition-opacity duration-500"></div>
             <div class="relative h-full w-full aspect-square rounded-3xl overflow-hidden border-4 border-white shadow-2xl">
               <img src={aboutImg} alt={aboutName} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
               <div class="absolute bottom-6 left-6 right-6 bg-white/80 backdrop-blur-md p-4 rounded-2xl border border-white/50">
                 <p class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-1">{aboutRole}</p>
                 <p class="text-sm font-medium text-slate-800">{aboutLocation}</p>
               </div>
             </div>
          </div>
          
          <div class="lg:col-span-8 flex flex-col justify-center">
            <div class="mb-8">
              <span class="text-indigo-600 font-extrabold text-xs uppercase tracking-[0.2em] block mb-3">{aboutTitle}</span>
              <h2 class="text-4xl md:text-5xl lg:text-7xl font-black text-slate-900 tracking-tighter">{aboutName}</h2>
            </div>
            
            <div class="bg-white/60 backdrop-blur-xl border border-white rounded-[2rem] p-8 md:p-10 shadow-xl shadow-slate-200/50 relative overflow-hidden">
               <div class="absolute top-0 left-0 w-2 h-full bg-gradient-to-b from-indigo-500 to-purple-500"></div>
               
               <h3 class="text-xl md:text-2xl font-bold text-slate-800 mb-4 tracking-tight">The Journey</h3>
               <p class="text-base md:text-lg text-slate-600 leading-relaxed font-normal whitespace-pre-line mb-8">
                 {aboutJourney}
               </p>
               
               <div class="w-full h-[1px] bg-slate-200 my-8"></div>

               <h3 class="text-xl md:text-2xl font-bold text-slate-800 mb-4 tracking-tight">Main Focus</h3>
               <p class="text-base md:text-lg text-slate-600 leading-relaxed font-normal whitespace-pre-line">
                 {aboutFocus}
               </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- AREA 3: GALLERY -->
    <section id="gallery" class="w-full min-h-screen flex items-center justify-center relative px-6 md:px-12 pt-20 pb-10">
      <div class="max-w-[1400px] w-full h-full max-h-[900px] flex flex-col justify-center">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 md:mb-12 shrink-0">
          <div>
            <span class="text-indigo-600 font-extrabold text-xs uppercase tracking-[0.2em] block mb-3">Selected Work</span>
            <h2 class="text-4xl md:text-5xl lg:text-7xl font-black text-slate-900 tracking-tighter">Gallery</h2>
          </div>
          <p class="text-slate-500 max-w-sm mt-4 md:mt-0 text-sm md:text-base md:text-right font-medium">
            Koleksi lengkap momen dan visual.
          </p>
        </div>

        {projects.length === 0 ? (
          <div class="w-full flex-1 border-2 border-slate-200 border-dashed rounded-[3rem] flex items-center justify-center font-bold text-slate-400">
            No gallery projects published yet.
          </div>
        ) : (
          <div class="flex flex-col flex-1 min-h-0 w-full">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6 flex-1 min-h-0 mb-6 overflow-y-auto pr-2">
              {projects.slice(0, 6).map((project) => (
                <a href="/galeri-perjalanan" class="group relative rounded-3xl overflow-hidden bg-slate-100 hover:shadow-2xl hover:shadow-indigo-500/20 transition-all duration-500 block border border-white/50 aspect-[4/3] w-full">
                  <img src={project.image_url || 'https://images.unsplash.com/photo-1469474968028?w=800'} alt={project.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" />
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/30 to-transparent opacity-70 group-hover:opacity-90 transition-opacity duration-500"></div>
                  <div class="absolute inset-0 p-6 flex flex-col justify-end z-20">
                    <div class="transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                      <h3 class="text-white font-black tracking-tight leading-tight text-xl mb-1">{project.title}</h3>
                      {project.description && (
                        <p class="text-slate-300 text-sm line-clamp-2 md:opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100 font-medium">{project.description}</p>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
            <div class="flex justify-center shrink-0">
              <a href="/galeri-perjalanan" class="inline-flex items-center gap-2 px-8 py-3 bg-slate-900 text-white font-bold rounded-full hover:bg-indigo-600 transition-colors shadow-lg shadow-indigo-500/20 group">
                Lebih Banyak (More)
                <span class="group-hover:translate-x-1 transition-transform">→</span>
              </a>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- AREA 4: BLOG / JOURNAL -->
    <section id="journal" class="w-full min-h-screen flex items-center justify-center relative px-6 md:px-12 pt-20 pb-10">
      <div class="max-w-[1400px] w-full h-full max-h-[900px] flex flex-col justify-center">
        <div class="mb-10 lg:mb-16 text-center flex flex-col items-center shrink-0">
          <span class="text-indigo-600 font-extrabold text-xs uppercase tracking-[0.2em] block mb-3">Thoughts & Journeys</span>
          <h2 class="text-4xl md:text-5xl lg:text-7xl font-black text-slate-900 tracking-tighter">The Journal</h2>
        </div>

        {articles.length === 0 ? (
           <div class="w-full flex-1 border-2 border-slate-200 border-dashed rounded-[3rem] flex items-center justify-center font-bold text-slate-400">
             No journal entries published.
           </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-10 flex-1 overflow-y-auto md:overflow-visible pb-10 md:pb-0 min-h-0">
            {articles.slice(0,3).map((article) => (
              <a href={`/blog/${article.slug}`} class="group flex flex-col bg-white rounded-[2.5rem] overflow-hidden hover:shadow-[0_20px_50px_rgb(0,0,0,0.06)] transition-all duration-500 border border-slate-100/80 hover:-translate-y-2 h-full">
                <div class="w-full aspect-[4/3] shrink-0 overflow-hidden relative bg-slate-100 p-3">
                  <div class="w-full h-full rounded-3xl overflow-hidden relative">
                    <img src={article.thumbnail_url || 'https://images.unsplash.com/photo-1499750310107?w=800'} alt={article.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    <div class="absolute inset-0 bg-slate-900/10 group-hover:bg-transparent transition-colors duration-500"></div>
                  </div>
                  <div class="absolute top-6 left-6 bg-white/90 backdrop-blur-md px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-widest text-indigo-600 shadow-sm">
                    Read
                  </div>
                </div>
                
                <div class="p-8 flex flex-col flex-1">
                  <h3 class="text-xl lg:text-2xl font-black text-slate-900 mb-4 group-hover:text-indigo-600 transition-colors leading-tight line-clamp-2">
                    {article.title}
                  </h3>
                  <p class="text-slate-500 text-sm line-clamp-3 leading-relaxed mb-6 flex-1 font-medium">
                    {article.excerpt}
                  </p>
                  <div class="text-slate-800 font-bold text-sm uppercase tracking-widest flex items-center gap-2 mt-auto">
                    Read Article <span class="group-hover:translate-x-2 transition-transform duration-300 text-indigo-600">→</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

  </div>
</Layout>

