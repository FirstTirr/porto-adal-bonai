---
import Layout from '../layouts/Layout.astro';
import { getProjects } from '../server/projects';

const projects = await getProjects();
---

<Layout>
	<h1>Portfolio Saya</h1>
	<p>Frontend: Astro.js · Database: Neon · Upload: Vercel Blob</p>

	{projects.length === 0 ? (
		<p>Belum ada project. Tambahkan dari halaman admin.</p>
	) : (
		<section class="grid">
			{projects.map((project) => (
				<article class="card">
					{project.image_url ? (
						<img src={project.image_url} alt={project.title} loading="lazy" />
					) : (
						<div class="placeholder">Tanpa Gambar</div>
					)}
					<h2>{project.title}</h2>
					{project.description ? <p>{project.description}</p> : null}
					{project.project_url ? (
						<a href={project.project_url} target="_blank" rel="noreferrer">Lihat Project</a>
					) : null}
				</article>
			))}
		</section>
	)}
</Layout>

<style>
	h1 {
		margin-bottom: 6px;
	}

	p {
		margin-top: 0;
		color: #4b5563;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 14px;
		margin-top: 18px;
	}

	.card {
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 10px;
		padding: 12px;
	}

	img,
	.placeholder {
		width: 100%;
		height: 160px;
		border-radius: 8px;
		object-fit: cover;
		background: #e5e7eb;
	}

	.placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 14px;
		color: #6b7280;
	}

	h2 {
		margin: 12px 0 6px;
		font-size: 20px;
	}

	.card p {
		min-height: 40px;
	}
</style>
