---
import Layout from '../layouts/Layout.astro';
import { getProjects } from '../server/projects';
import { getArticles } from '../server/articles';

const projects = await getProjects();
const articles = await getArticles();
---

<Layout>
	<section class="hero">
		<p class="eyebrow">Portfolio Adal Bonai</p>
		<h1>Petualangan Sehat untuk Jiwa dan Raga</h1>
		<p class="subtitle">
			Website ini berisi perjalanan proyek bertema petualangan dan kesehatan, plus artikel inspiratif
			untuk gaya hidup aktif.
		</p>
	</section>

	<section id="about" class="section">
		<h2>About Adal Bonai</h2>
		<p>
			Adal Bonai adalah kreator digital yang menggabungkan semangat eksplorasi alam, kebugaran, dan
			cerita hidup sehat ke dalam karya portofolio dan artikel edukatif.
		</p>
	</section>

	<section class="section">
		<h2>Project Pilihan</h2>
		{projects.length === 0 ? (
			<p class="empty">Belum ada project. Tambahkan dari halaman admin.</p>
		) : (
			<div class="grid">
				{projects.map((project) => (
					<article class="card">
						{project.image_url ? (
							<img src={project.image_url} alt={project.title} loading="lazy" />
						) : (
							<div class="placeholder">Tanpa Gambar</div>
						)}
						<h3>{project.title}</h3>
						{project.description ? <p>{project.description}</p> : null}
						{project.project_url ? (
							<a href={project.project_url} target="_blank" rel="noreferrer">Lihat Project</a>
						) : null}
					</article>
				))}
			</div>
		)}
	</section>

	<section id="blog" class="section">
		<h2>Blog & Artikel</h2>
		{articles.length === 0 ? (
			<p class="empty">Belum ada artikel. Tambahkan dari halaman admin.</p>
		) : (
			<div class="grid">
				{articles.map((article) => (
					<article class="card">
						<img src={article.thumbnail_url} alt={article.title} loading="lazy" />
						<h3>{article.title}</h3>
						<p>{article.excerpt}</p>
						<a href={`/blog/${article.slug}`}>Baca Artikel</a>
					</article>
				))}
			</div>
		)}
	</section>
</Layout>

<style>
	.hero {
		background: linear-gradient(135deg, #0f766e, #0c4a6e);
		color: #fff;
		padding: 26px;
		border-radius: 16px;
		margin-bottom: 18px;
	}

	.eyebrow {
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 12px;
		font-weight: 700;
		opacity: 0.85;
	}

	h1 {
		margin: 8px 0;
		font-size: 38px;
	}

	.subtitle {
		margin: 0;
		max-width: 760px;
		font-size: 17px;
		line-height: 1.7;
	}

	.section {
		margin: 18px 0;
	}

	h2 {
		font-size: 28px;
		margin: 0 0 10px;
	}

	p {
		margin: 0;
		color: #4b5563;
		line-height: 1.7;
	}

	.empty {
		padding: 12px;
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 14px;
		margin-top: 12px;
	}

	.card {
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 10px;
		padding: 12px;
	}

	img,
	.placeholder {
		width: 100%;
		height: 160px;
		border-radius: 8px;
		object-fit: cover;
		background: #e5e7eb;
	}

	.placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 14px;
		color: #6b7280;
	}

	h2 {
		margin: 12px 0 6px;
	}

	h3 {
		margin: 12px 0 6px;
		font-size: 21px;
	}

	.card p {
		min-height: 40px;
	}

	.card a {
		display: inline-block;
		margin-top: 8px;
		color: #0f766e;
	}
</style>
