---
import Layout from '../../layouts/Layout.astro';
import { getArticleBySlug } from '../../server/articles';

const slug = Astro.params.slug ?? '';
const article = await getArticleBySlug(slug);

if (!article) {
	return Astro.redirect('/');
}
---

<Layout>
	<article class="article-detail">
		<p class="breadcrumb"><a href="/">← Kembali ke Beranda</a></p>
		<h1>{article.title}</h1>
		<img src={article.thumbnail_url} alt={article.title} />
		<p class="meta">
			Dipublikasikan {new Date(article.created_at).toLocaleDateString('id-ID', {
				year: 'numeric',
				month: 'long',
				day: 'numeric',
			})}
		</p>
		<div class="content">{article.content}</div>
	</article>
</Layout>

<style>
	.article-detail {
		background: white;
		padding: 20px;
		border-radius: 14px;
		border: 1px solid #dbe4ef;
	}

	.breadcrumb {
		margin-top: 0;
	}

	h1 {
		margin: 0 0 12px;
		font-size: 34px;
	}

	img {
		width: 100%;
		height: 360px;
		object-fit: cover;
		border-radius: 10px;
		margin-bottom: 12px;
	}

	.meta {
		color: #6b7280;
		font-size: 14px;
	}

	.content {
		white-space: pre-wrap;
		line-height: 1.8;
		font-size: 17px;
	}
</style>
