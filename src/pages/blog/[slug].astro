---
import Layout from '../../layouts/Layout.astro';
import { getArticleBySlug } from '../../server/articles';

const slug = Astro.params.slug ?? '';
const article = await getArticleBySlug(slug);

if (!article) {
	return Astro.redirect('/');
}
---

<Layout>
	<article class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm max-w-4xl mx-auto my-12">
		<p class="mt-0 mb-4"><a href="/" class="text-teal-700 hover:text-teal-800 no-underline font-medium inline-flex items-center transition-colors">← Kembali ke Beranda</a></p>
		<h1 class="m-0 mb-3 text-[34px] font-bold text-gray-900 leading-tight">{article.title}</h1>
		<img src={article.thumbnail_url} alt={article.title} class="w-full h-[360px] object-cover rounded-xl mb-3" />
		<p class="text-gray-500 text-sm mb-6 pb-6 border-b border-gray-100">
			Dipublikasikan {new Date(article.created_at).toLocaleDateString('id-ID', {
				year: 'numeric',
				month: 'long',
				day: 'numeric',
			})}
		</p>
		<div class="whitespace-pre-wrap leading-[1.8] text-[17px] text-gray-800">{article.content}</div>
	</article>
</Layout>
