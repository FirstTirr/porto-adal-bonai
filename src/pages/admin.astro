---
import Layout from '../layouts/Layout.astro';
import { getArticles } from '../server/articles';
import { isAdminAuthenticated } from '../server/admin-auth';

const authenticated = isAdminAuthenticated(Astro.cookies);
const articles = authenticated ? await getArticles() : [];
---

<Layout>
	<h1>Admin Blog</h1>
	<p>Login admin, lalu kelola artikel. Thumbnail wajib diisi.</p>

	{!authenticated ? (
		<section class="panel">
			<h2>Login Admin</h2>
			<form id="login-form">
				<label>
					Username
					<input name="username" required />
				</label>
				<label>
					Password
					<input name="password" type="password" required />
				</label>
				<button type="submit">Login</button>
				<p id="login-status"></p>
			</form>
		</section>
	) : (
		<>
			<section class="panel">
				<div class="actions">
					<h2>Tambah / Edit Artikel</h2>
					<button id="logout-button" class="danger" type="button">Logout</button>
				</div>
				<form id="article-form">
					<input name="id" type="hidden" />
					<label>
						Judul
						<input name="title" required />
					</label>
					<label>
						Ringkasan
						<textarea name="excerpt" rows="2" required></textarea>
					</label>
					<label>
						Konten Artikel
						<textarea name="content" rows="8" required></textarea>
					</label>
					<label>
						Thumbnail (wajib, jpg/png/webp)
						<input name="thumbnail" type="file" accept="image/jpeg,image/png,image/webp" />
					</label>
					<input name="thumbnailUrl" type="hidden" />
					<button type="submit">Simpan Artikel</button>
					<button id="reset-button" type="button" class="light">Reset Form</button>
					<p id="article-status"></p>
				</form>
			</section>

			<section class="panel">
				<h2>Daftar Artikel</h2>
				{articles.length === 0 ? (
					<p>Belum ada artikel.</p>
				) : (
					<ul class="list">
						{articles.map((article) => (
							<li>
								<div>
									<strong>{article.title}</strong>
									<p>{article.excerpt}</p>
								</div>
								<div class="actions">
									<button
										type="button"
										class="edit"
										data-id={article.id}
										data-title={article.title}
										data-excerpt={article.excerpt}
										data-content={article.content}
										data-thumbnail={article.thumbnail_url}
									>
										Edit
									</button>
									<button class="delete" type="button" data-id={article.id}>Hapus</button>
								</div>
							</li>
						))}
					</ul>
				)}
			</section>
		</>
	)}
</Layout>

<script>
	const loginForm = document.getElementById('login-form');
	const loginStatus = document.getElementById('login-status');

	if (loginForm instanceof HTMLFormElement && loginStatus) {
		loginForm.addEventListener('submit', async (event) => {
			event.preventDefault();
			loginStatus.textContent = 'Memproses login...';

			const data = new FormData(loginForm);
			const response = await fetch('/api/admin/login', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					username: String(data.get('username') || ''),
					password: String(data.get('password') || ''),
				}),
			});

			if (!response.ok) {
				loginStatus.textContent = 'Login gagal';
				return;
			}

			window.location.reload();
		});
	}

	const articleForm = document.getElementById('article-form');
	const articleStatus = document.getElementById('article-status');
	const resetButton = document.getElementById('reset-button');
	const logoutButton = document.getElementById('logout-button');

	function clearForm() {
		if (!(articleForm instanceof HTMLFormElement)) return;
		articleForm.reset();
		const idInput = articleForm.elements.namedItem('id');
		const thumbnailUrlInput = articleForm.elements.namedItem('thumbnailUrl');
		if (idInput instanceof HTMLInputElement) idInput.value = '';
		if (thumbnailUrlInput instanceof HTMLInputElement) thumbnailUrlInput.value = '';
	}

	if (articleForm instanceof HTMLFormElement && articleStatus) {
		articleForm.addEventListener('submit', async (event) => {
			event.preventDefault();
			articleStatus.textContent = 'Menyimpan artikel...';

			const data = new FormData(articleForm);
			const idValue = parseInt(String(data.get('id') || ''), 10) || 0;
			const title = String(data.get('title') || '').trim();
			const excerpt = String(data.get('excerpt') || '').trim();
			const content = String(data.get('content') || '').trim();
			const existingThumbnail = String(data.get('thumbnailUrl') || '').trim();
			const thumbnailFile = data.get('thumbnail');

			let thumbnailUrl = existingThumbnail;

			if (thumbnailFile instanceof File && thumbnailFile.size > 0) {
				const uploadData = new FormData();
				uploadData.append('file', thumbnailFile);
				const uploadRes = await fetch('/api/upload', {
					method: 'POST',
					body: uploadData,
				});

				if (!uploadRes.ok) {
					const uploadError = await uploadRes.json().catch(() => null);
					articleStatus.textContent = uploadError?.error || 'Upload thumbnail gagal';
					return;
				}

				const uploadBody = await uploadRes.json();
				thumbnailUrl = String(uploadBody.url || '');
			}

			if (!thumbnailUrl) {
				articleStatus.textContent = 'Thumbnail wajib diisi';
				return;
			}

			const method = idValue > 0 ? 'PUT' : 'POST';
			const payload = {
				id: idValue,
				title,
				excerpt,
				content,
				thumbnailUrl,
			};

			const response = await fetch('/api/articles', {
				method,
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
			});

			if (!response.ok) {
				const errBody = await response.json().catch(() => null);
				articleStatus.textContent = errBody?.error || 'Gagal menyimpan artikel';
				return;
			}

			alert('Sukses! Artikel berhasil disimpan.');
			window.location.reload();
		});

		document.querySelectorAll('.delete').forEach((button) => {
			button.addEventListener('click', async () => {
				const confirmDelete = confirm('Apakah Anda yakin ingin menghapus artikel ini?');
				if (!confirmDelete) return;

				const id = Number(button.getAttribute('data-id'));
				if (!id) return;

				const response = await fetch('/api/articles', {
					method: 'DELETE',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ id }),
				});

				if (response.ok) {
					alert('Sukses! Artikel berhasil dihapus.');
					window.location.reload();
				} else {
					alert('Gagal menghapus artikel.');
				}
			});
		});

		document.querySelectorAll('.edit').forEach((button) => {
			button.addEventListener('click', () => {
				const idInput = articleForm.elements.namedItem('id');
				const titleInput = articleForm.elements.namedItem('title');
				const excerptInput = articleForm.elements.namedItem('excerpt');
				const contentInput = articleForm.elements.namedItem('content');
				const thumbnailUrlInput = articleForm.elements.namedItem('thumbnailUrl');

				if (
					!(idInput instanceof HTMLInputElement) ||
					!(titleInput instanceof HTMLInputElement) ||
					!(excerptInput instanceof HTMLTextAreaElement) ||
					!(contentInput instanceof HTMLTextAreaElement) ||
					!(thumbnailUrlInput instanceof HTMLInputElement)
				) {
					return;
				}

				idInput.value = button.getAttribute('data-id') || '';
				titleInput.value = button.getAttribute('data-title') || '';
				excerptInput.value = button.getAttribute('data-excerpt') || '';
				contentInput.value = button.getAttribute('data-content') || '';
				thumbnailUrlInput.value = button.getAttribute('data-thumbnail') || '';
				articleStatus.textContent = 'Mode edit aktif. Upload thumbnail baru jika ingin mengganti gambar.';
			});
		});

		if (resetButton instanceof HTMLButtonElement) {
			resetButton.addEventListener('click', () => {
				clearForm();
				articleStatus.textContent = '';
			});
		}
	}

	if (logoutButton instanceof HTMLButtonElement) {
		logoutButton.addEventListener('click', async () => {
			await fetch('/api/admin/logout', { method: 'POST' });
			window.location.reload();
		});
	}
</script>

<style>
	h1 {
		margin-bottom: 8px;
	}

	.panel {
		background: white;
		padding: 16px;
		border-radius: 10px;
		border: 1px solid #e5e7eb;
		margin-bottom: 14px;
	}

	form {
		display: grid;
		gap: 12px;
	}

	.actions {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 12px;
	}

	label {
		display: grid;
		gap: 6px;
		font-weight: 600;
	}

	input,
	textarea,
	button {
		font: inherit;
		padding: 10px;
		border-radius: 8px;
		border: 1px solid #d1d5db;
	}

	button {
		cursor: pointer;
		background: #111827;
		color: white;
		font-weight: 600;
		width: fit-content;
	}

	button.light {
		background: #334155;
	}

	button.danger,
	button.delete {
		background: #b91c1c;
	}

	button.edit {
		background: #0369a1;
	}

	.list {
		list-style: none;
		padding: 0;
		display: grid;
		gap: 8px;
	}

	.list li {
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 8px;
		padding: 10px;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 12px;
	}

	.list p {
		margin: 6px 0 0;
		color: #4b5563;
	}

	#login-status,
	#article-status {
		margin: 0;
		color: #4b5563;
	}
</style>
