---
import '../styles/global.css';
import { getSettings } from '../server/settings';

const settings = await getSettings();
const getSetting = (key: string, defaultValue: string = '') => settings[key] || defaultValue;

const socialWa = getSetting("social_wa", "");
const socialIg = getSetting("social_ig", "");
const socialTiktok = getSetting("social_tiktok", "");
const socialLinkedin = getSetting("social_linkedin", "");
const socialFacebook = getSetting("social_facebook", "");
const socialX = getSetting("social_x", "");
---
<!doctype html>
<html lang="id" class="scroll-smooth" style="color-scheme: light;">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<title>Adal Bonai Portfolio</title>
</head>
<body class="m-0 font-sans bg-slate-50 text-gray-900 relative flex flex-col min-h-screen">
<!-- Floating Navbar Pill (Desktop & Mobile) -->
<header class="fixed top-4 inset-x-0 z-50 flex justify-center w-full px-4 pointer-events-none">
<div class="pointer-events-auto relative w-full max-w-3xl">
<!-- The Main Pill Nav -->
<nav class="bg-white/70 backdrop-blur-md border border-white/40 shadow-[0_8px_30px_rgb(0,0,0,0.04)] rounded-full px-6 py-3 flex items-center justify-between w-full h-[60px] transition-all duration-500 z-50 relative">
<!-- Brand / Logo -->
<a href="/" class="text-xl font-extrabold tracking-tighter text-teal-900 flex items-center gap-2 group decoration-transparent">
<div class="w-8 h-8 rounded-full bg-gradient-to-br from-teal-400 to-teal-800 flex items-center justify-center text-white shadow-md group-hover:rotate-12 transition-transform duration-300">A</div>
<span>Bonai</span>
</a>

<!-- Desktop Links -->
<div class="hidden md:flex items-center gap-1 bg-white/50 p-1.5 rounded-full border border-white/60">
<a href="/" class="text-sm font-bold px-4 py-1.5 rounded-full text-gray-700 hover:text-teal-800 hover:bg-white/80 transition-all decoration-transparent">Beranda</a>
<a href="/#about" class="text-sm font-bold px-4 py-1.5 rounded-full text-gray-700 hover:text-teal-800 hover:bg-white/80 transition-all decoration-transparent">Tentang</a>
<a href="/#gallery" class="text-sm font-bold px-4 py-1.5 rounded-full text-gray-700 hover:text-teal-800 hover:bg-white/80 transition-all decoration-transparent">Galeri</a>
<a href="/#journal" class="text-sm font-bold px-4 py-1.5 rounded-full text-gray-700 hover:text-teal-800 hover:bg-white/80 transition-all decoration-transparent">Blog</a>
<a href="/admin" class="text-sm font-bold px-4 py-1.5 rounded-full text-gray-700 hover:text-teal-800 hover:bg-white/80 transition-all decoration-transparent">Admin</a>
</div>

<!-- Custom Hamburger (Mobile) -->
<button id="menu-btn" class="md:hidden relative w-10 h-10 rounded-full bg-white shadow-sm border border-gray-100 flex flex-col items-center justify-center gap-[5px] overflow-hidden group z-50">
<span class="w-5 h-[2px] bg-teal-900 rounded-full transform transition-all duration-300 origin-center group-hover:bg-teal-500"></span>
<span class="w-5 h-[2px] bg-teal-900 rounded-full transform transition-all duration-300 origin-center group-hover:bg-teal-500 translate-x-1 group-hover:translate-x-0"></span>
<span class="w-5 h-[2px] bg-teal-900 rounded-full transform transition-all duration-300 origin-center group-hover:bg-teal-500 -translate-x-1 group-hover:translate-x-0"></span>
</button>
</nav>

<!-- Unique Full Screen / Clip-Path Menu Overlay -->
<div id="mobile-menu-overlay" class="fixed inset-0 w-full h-[100dvh] bg-white/95 backdrop-blur-xl z-40 flex flex-col justify-center items-center pointer-events-none transition-all duration-500" style="clip-path: circle(0px at calc(100% - 44px) 34px);">
<!-- Mobile Content Box -->
<div id="mobile-menu-content" class="w-full flex-1 flex flex-col justify-center items-center opacity-0 transition-opacity duration-300">
<div class="flex flex-col items-center gap-8 w-full px-8">
<a href="/" class="mobile-link text-3xl font-extrabold text-teal-950 no-underline translate-y-8 opacity-0 transition-all duration-500 hover:text-teal-600 hover:scale-110">Beranda</a>
<a href="/#about" class="mobile-link text-3xl font-extrabold text-teal-950 no-underline translate-y-8 opacity-0 transition-all duration-500 delay-[50ms] hover:text-teal-600 hover:scale-110">Tentang</a>
<a href="/#gallery" class="mobile-link text-3xl font-extrabold text-teal-950 no-underline translate-y-8 opacity-0 transition-all duration-500 delay-[100ms] hover:text-teal-600 hover:scale-110">Galeri</a>
<a href="/#journal" class="mobile-link text-3xl font-extrabold text-teal-950 no-underline translate-y-8 opacity-0 transition-all duration-500 delay-[150ms] hover:text-teal-600 hover:scale-110">Blog</a>
<a href="/admin" class="mobile-link text-3xl font-extrabold text-teal-950 no-underline translate-y-8 opacity-0 transition-all duration-500 delay-[200ms] hover:text-teal-600 hover:scale-110">Admin</a>
</div>
</div>

<!-- Decorative Elements -->
<div class="absolute bottom-10 inset-x-0 flex justify-center text-teal-200">
<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-[spin_6s_linear_infinite]"><path d="M12 2v20M17 5l-10 14M22 12H2M19 17L5 7"/></svg>
</div>
</div>
</div>
</header>

<main class="w-full w-full max-w-[1400px] mx-auto pt-24 pb-8 px-4 border-0 flex-1 flex flex-col">
<slot />
</main>

<!-- Footer Section -->
<footer class="w-full bg-white border-t border-slate-200 mt-auto py-8 px-6 md:px-12 z-10 relative">
  <div class="max-w-[1400px] mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="text-slate-500 font-medium text-sm border-t border-slate-200 mt-10 pt-6 text-center lg:text-left lg:border-t-0 lg:mt-0 lg:pt-0">
      &copy; {new Date().getFullYear()} {getSetting("about_name", "Adal Bonai")}. All rights reserved.
    </div>
    <div class="flex items-center justify-center gap-5 mt-4 lg:mt-0">
      {socialWa && (
        <a href={socialWa} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-emerald-500 transition-colors" aria-label="WhatsApp">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.405-.883-.733-1.48-1.64-1.653-1.937-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        </a>
      )}
      {socialIg && (
        <a href={socialIg} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-pink-600 transition-colors" aria-label="Instagram">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      )}
      {socialTiktok && (
        <a href={socialTiktok} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-black transition-colors" aria-label="TikTok">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 2.78-1.15 5.54-3.33 7.37-1.92 1.62-4.55 2.28-6.95 1.88-2.61-.45-4.96-2.06-6.1-4.46-1.16-2.58-1-5.63.45-8.08 1.34-2.28 3.73-3.85 6.35-4.31v4.06c-1.39.28-2.73.98-3.66 2.05-1.07 1.25-1.5 3.01-1.1 4.61.35 1.42 1.33 2.67 2.66 3.23 1.32.55 2.92.51 4.18-.18 1.46-.78 2.45-2.31 2.58-3.98.05-11.23.01-22.45.03-33.68z"/></svg>
        </a>
      )}
      {socialLinkedin && (
        <a href={socialLinkedin} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-blue-600 transition-colors" aria-label="LinkedIn">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      )}
      {socialFacebook && (
        <a href={socialFacebook} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-blue-700 transition-colors" aria-label="Facebook">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      )}
      {socialX && (
        <a href={socialX} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-black transition-colors" aria-label="X">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
        </a>
      )}
    </div>
  </div>
</footer>

<!-- Script for Hamburger Interaction -->
<script is:inline>
// Wrap in an IIFE to avoid global scope pollution
(function() {
const menuBtn = document.getElementById('menu-btn');
const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
const mobileMenuContent = document.getElementById('mobile-menu-content');
const mobileLinks = document.querySelectorAll('.mobile-link');
const spans = menuBtn ? menuBtn.querySelectorAll('span') : [];
let isOpen = false;

function toggleMenu() {
isOpen = !isOpen;

// Toggle Hamburger Animation
if (isOpen) {
// Morph menu button to X
if (spans.length >= 3) {
spans[0].classList.add('rotate-45', 'translate-y-[7px]');
spans[1].classList.add('opacity-0', 'scale-x-0');
spans[1].classList.remove('translate-x-1');
spans[2].classList.add('-rotate-45', '-translate-y-[7px]');
spans[2].classList.remove('-translate-x-1');
}

// Expand circular mask
mobileMenuOverlay.style.clipPath = 'circle(150% at calc(100% - 44px) 34px)';
mobileMenuOverlay.classList.remove('pointer-events-none');
mobileMenuOverlay.classList.add('pointer-events-auto');

// Fade in content
setTimeout(() => {
mobileMenuContent.classList.remove('opacity-0');
mobileLinks.forEach(link => {
link.classList.remove('translate-y-8', 'opacity-0');
});
}, 200);

} else {
// Revert to hamburger
if (spans.length >= 3) {
spans[0].classList.remove('rotate-45', 'translate-y-[7px]');
spans[1].classList.remove('opacity-0', 'scale-x-0');
spans[1].classList.add('translate-x-1');
spans[2].classList.remove('-rotate-45', '-translate-y-[7px]');
spans[2].classList.add('-translate-x-1');
}

// Hide content
mobileLinks.forEach(link => {
link.classList.add('translate-y-8', 'opacity-0');
});
mobileMenuContent.classList.add('opacity-0');

// Shrink circular mask
mobileMenuOverlay.style.clipPath = 'circle(0px at calc(100% - 44px) 34px)';
mobileMenuOverlay.classList.remove('pointer-events-auto');
mobileMenuOverlay.classList.add('pointer-events-none');
}
}

if (menuBtn && mobileMenuOverlay && mobileMenuContent) {
menuBtn.addEventListener('click', toggleMenu);

// Close menu when clicking a link
mobileLinks.forEach(link => {
link.addEventListener('click', () => {
if (isOpen) {
toggleMenu();
}
});
});
}
})();
</script>
</body>
</html>